# ──────────────────────────────────────────────────────────────────────
# Frontend env — copy to frontend/.env and fill in your own values.
# All EXPO_PUBLIC_* values are baked into the static bundle at build time.
# ──────────────────────────────────────────────────────────────────────

# OnSpace / Supabase project — used for user login only.
# (You can also use the built-in "god user" bypass to skip Supabase
#  entirely — see README.md.)
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.backend.onspace.ai
EXPO_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJI...

# AXIOM runtime URL — points at the FastAPI backend in this repo.
# In development this is usually http://localhost:8001 or your container's
# external preview URL.
EXPO_PUBLIC_AXIOM_RUNTIME_URL=https://your-backend.example.com
