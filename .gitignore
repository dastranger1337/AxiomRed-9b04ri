# ──────────────────────────────────────────────────────────────────────
# Axiom Red-Team — .gitignore
# ──────────────────────────────────────────────────────────────────────

# Dependencies
node_modules/
frontend/.expo/
frontend/dist/
backend/__pycache__/
backend/*.pyc
backend/.pytest_cache/
.ruff_cache/

# Build outputs
*.log
*.pid
.DS_Store

# Local cache / scratch dirs
runtime_workspace/
.cache/

# Editor
.vscode/
.idea/

# NOTE: .env files ARE tracked intentionally — the Emergent platform
# expects MONGO_URL / DB_NAME / EXPO_PUBLIC_* to come with the repo.
# Sensitive overrides should go in `.env.local` (ignored below).
*.env.local
.env.local

# Secret material that should never be committed
credentials.json
*.pem
*.key
.credentials

# Wordlists (rockyou is 130 MB — installed at runtime instead)
backend/wordlists/

# Platform-managed (keep)
# .emergent/
