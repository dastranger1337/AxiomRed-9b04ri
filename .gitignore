# ──────────────────────────────────────────────────────────────────────
# Axiom Red-Team CLI — .gitignore
# ──────────────────────────────────────────────────────────────────────

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
pip-log.txt
MANIFEST

# Virtual environments
venv/
env/
ENV/
.venv

# IDE & Editor
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Environment & Configuration
# IMPORTANT: .env contains sensitive API keys — never commit!
.env
.env.local
.env.*.local
credentials.json

# Secrets
*.pem
*.key
.credentials

# Cache & Build
*.log
*.pid
.ruff_cache/
.pytest_cache/
.mypy_cache/
.cache/

# Runtime
runtime_workspace/run-*/
*.tmp
*.temp
*.bak

# Wordlists (installed at runtime)
backend/wordlists/
wordlists/

# Artifacts
full_app_artifact.txt
