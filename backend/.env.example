# ──────────────────────────────────────────────────────────────────────
# Backend env — copy to backend/.env and fill in your own values.
# ──────────────────────────────────────────────────────────────────────

# MongoDB (optional — used for future persistence; the runtime works without it)
MONGO_URL=mongodb://localhost:27017
DB_NAME=axiom_redteam

# Emergent Universal LLM key — works for Anthropic, OpenAI, Gemini.
# Get yours from https://app.emergent.sh → Profile → Universal Key.
EMERGENT_LLM_KEY=sk-emergent-XXXXXXXXXXXXXXXXX

# Default LLM provider + model for the chat / agent endpoints
DEFAULT_LLM_PROVIDER=anthropic
DEFAULT_LLM_MODEL=claude-sonnet-4-5-20250929

# Default /api/exec timeout in seconds (max enforced server-side: 300)
EXEC_TIMEOUT_SECONDS=120
